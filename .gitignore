# ============================================================
# BOM Diff Tool - .gitignore
# ============================================================

# ── 設定ファイル（APIキー・認証情報を含む） ──
config.ini

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ── 仮想環境 ──
.venv/
venv/
env/
ENV/

# ── Excel ファイル（サンプル以外） ──
old.xlsx
new.xlsx
bom_diff_report.xlsx
# サンプルファイルは除外しない
!sample_old.xlsx
!sample_new.xlsx

# ── IDE / エディタ ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── テスト・カバレッジ ──
.pytest_cache/
.coverage
htmlcov/

# ── Claude Code 内部設定 ──
CLAUDE.md

# ── デバッグ用スクリプト ──
debug_*.py
